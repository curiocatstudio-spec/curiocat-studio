---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size = 220 } = Astro.props;
---

<video
  class={`logo-video ${className}`}
  style={`width:${size}px;height:${size}px;`}
  autoplay
  loop
  muted
  playsinline
  disablepictureinpicture
  preload="auto"
  poster="/images/logo-poster.jpg"
  aria-label="CurioCat Studio animated logo"
>
  <source src="/videos/logo-loop.mp4" type="video/mp4" />
</video>
