---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'CurioCat Studio is an independent game development studio based in Surabaya, Indonesia, crafting memorable interactive experiences through storytelling, immersive worlds, and thoughtful design.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <meta 
    name="google-site-verification" 
    content="9m4bJFNCQQhlMti1-cSZFkEA6aecCf23VCL2Ieev-Ys" />

    <title>{title} · CurioCat Studio</title>
    <meta name="description" content={description} />

    <meta name="author" content="CurioCat Studio" />
    <meta name="application-name" content="CurioCat Studio" />
    <meta name="theme-color" content="#111111" />

    <meta property="og:title" content={`${title} · CurioCat Studio`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/logo.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="CurioCat Studio" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CurioCat Studio",
  "url": "https://curiocat-studio.vercel.app",
  "logo": "https://curiocat-studio.vercel.app/images/logo.png",
  "description": "CurioCat Studio is an independent game development studio creating story-driven experiences.",
  "sameAs": [
    "https://www.youtube.com/@CurioCatStudio"
  ]
})} />

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-G0L0E9JX6F"></script>

<script is:inline>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());

gtag('config', 'G-G0L0E9JX6F');
</script>

  </head>
  <body class="bg-void text-bone font-body antialiased">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <script src="../scripts/reveal.js"></script>
  </body>
</html>
